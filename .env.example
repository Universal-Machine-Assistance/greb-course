# Copy to .env in the repo root (gitignored):
#   cp .env.example .env
#
# Optional overrides: .env.local (also gitignored; loaded after .env)

# ── Anthropic cloud (default upstream https://api.anthropic.com/v1/messages)
GREB_ANTHROPIC_API_KEY=
# ANTHROPIC_API_KEY=

# ── Local “Claude” / any Anthropic-compatible POST /v1/messages
# Anthropic does not ship a local model; use a proxy such as LiteLLM that
# exposes the Messages API, then point the greb-course server at it:
#
#   GREB_ANTHROPIC_API_BASE=http://127.0.0.1:4000
#
# For http://127.0.0.1 or http://localhost you may omit GREB_ANTHROPIC_API_KEY
# (keyless proxy). For a non-loopback host, set:
#   GREB_ANTHROPIC_KEYLESS_PROXY=true
#
# Full URL override (rare):
# GREB_ANTHROPIC_MESSAGES_UPSTREAM=http://127.0.0.1:4000/v1/messages

# Browser talks to server proxy `/api/anthropic/messages` when either a key
# is set or keyless-local proxy is allowed — you usually do not need this:
# GREB_ANTHROPIC_MESSAGES_URL=https://api.anthropic.com/v1/messages

# ── Auth (catalog protection)
# Protects GET / (catalog) behind a login page.
# If GREB_AUTH_PASS is NOT set, auth is DISABLED — useful for local dev.
# Set both variables in Railway environment variables for production.
GREB_AUTH_USER=admin
GREB_AUTH_PASS=

# ── Kie AI image generation (https://docs.kie.ai/)
# Get a key at https://kie.ai/api-key (must whitelist server IP)
KIE_API=

# ── OpenRouter (preferred if set — overrides Anthropic for editor LLM)
# Get a key at https://openrouter.ai/keys
# Uses model: anthropic/claude-sonnet-4 via OpenRouter proxy
OPENROUTER_API=
